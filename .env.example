# CareerVision Environment Variables
# Copy this file to .env and fill in your values

# =============== Frontend Configuration ===============
VITE_API_URL=http://localhost:3000/api

# =============== Backend Configuration ===============
# Database
DATABASE_URL=postgresql://user:password@localhost:5432/careervision
NODE_ENV=development
PORT=3000

# =============== Study Materials API Keys ===============
# Get these from their respective services

# Boclips (1.7M+ educational videos)
# Sign up: https://boclips.com/developer
BOCLIPS_API_KEY=

# YouTube Data API (for educational content search)
# Setup: https://console.cloud.google.com
YOUTUBE_API_KEY=

# Coursera (optional, for affiliate links)
# Apply: https://www.coursera.org/about/careers/partnerships/affiliates
COURSERA_API_KEY=
COURSERA_AFFILIATE_TOKEN=

# Udemy (optional, for affiliate links)
# Join: https://www.udemy.com/affiliate-program
UDEMY_AFFILIATE_ID=

# =============== Firebase Configuration ===============
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_API_KEY=your-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com

# =============== Gemini AI Configuration ===============
GEMINI_API_KEY=your-gemini-api-key

# =============== Other Services ===============
# Add other API keys as needed
