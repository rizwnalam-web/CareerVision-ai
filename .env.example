# CareerVision Environment Variables
# Copy this file to server/.env and fill in your values

# =============== Server ===============
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000

# =============== Database ===============
DATABASE_URL=postgresql://user:password@host/careervision?sslmode=require

# =============== LLM Providers (tried in order: Groq → Gemini → DeepSeek) ===============
GROQ_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
LLM_GATEWAY_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_MODEL=gemini-2.0-flash

# =============== Study Materials ===============
YOUTUBE_API_KEY=

# =============== Frontend (Vite) ===============
VITE_API_URL=http://localhost:3000/api
