rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdminEmail() {
      return isSignedIn() && request.auth.token.email == 'support@careervision.ai';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- UserProfile Validation ---
    function isValidUserProfile(data) {
      return data.keys().hasAll(['name', 'email', 'uid', 'createdAt', 'updatedAt']) &&
             data.keys().size() >= 5 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email == request.auth.token.email &&
             data.uid is string && data.uid == request.auth.uid &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    // --- Collection Routes ---
    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUserProfile(incoming());
      allow update: if isOwner(userId) && isValidId(userId) && (
        // Identity validation (Immutable fields)
        incoming().email == existing().email &&
        incoming().uid == existing().uid &&
        incoming().createdAt == existing().createdAt &&
        incoming().updatedAt == request.time &&
        
        // Field validation
        (incoming().name is string && incoming().name.size() > 0 && incoming().name.size() <= 100) &&
        
        // Allowed keys check
        incoming().diff(existing()).affectedKeys().hasOnly([
          'name', 'age', 'education', 'interests', 'budget', 'country', 
          'targetLocation', 'targetCareerId', 'completedMilestones', 
          'academicPerformance', 'financialProfile', 'updatedAt'
        ])
      );
      allow delete: if false;
    }

    match /siteConfig/globalIntel {
      allow get: if true;
      allow list: if false;
      allow create, update: if isAdminEmail();
      allow delete: if false;
    }

    // Allow connection test
    match /test/connection {
      allow read: if true;
    }
  }
}
